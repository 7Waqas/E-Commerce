@model List<E_Commerce.Models.Category>
@{
    ViewData["Title"] = "Manage Categories";
    var counts = ViewBag.ProductCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="dashboard-page">
    <div class="container">

        <div class="dash-header">
            <div>
                <h1 class="dash-title">Categories</h1>
                <p class="dash-sub">Manage product categories</p>
            </div>
            <div class="d-flex gap-2">
                <a href="/Product/Dashboard" class="btn-secondary-nav">
                    <i class="fas fa-th-large"></i> Products
                </a>
                <a href="/Category/Create" class="add-product-btn">
                    <i class="fas fa-plus"></i> Add Category
                </a>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="success-toast"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="error-toast"><i class="fas fa-exclamation-triangle"></i> @TempData["Error"]</div>
        }

        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🗂️</div>
                <h3>No categories yet</h3>
                <p>Create your first category to organize products.</p>
            </div>
        }
        else
        {
            <div class="cat-grid">
                @foreach (var cat in Model)
                {
                    var count = counts.ContainsKey(cat.Id) ? counts[cat.Id] : 0;
                    <div class="cat-card">
                        <div class="cat-card-top">
                            <div class="cat-icon-wrap">🗂️</div>
                            <div class="cat-actions">
                                <a href="/Category/Edit/@cat.Id" class="btn-edit">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                                <form asp-action="Delete" asp-controller="Category" method="post"
                                      style="display:inline"
                                      onsubmit="return confirm('Delete category @cat.Name?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@cat.Id" />
                                    <button type="submit" class="btn-delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        <h3 class="cat-name">@cat.Name</h3>
                        <p class="cat-desc">@(cat.Description ?? "No description")</p>
                        <div class="cat-footer">
                            <span class="cat-count">@count product@(count != 1 ? "s" : "")</span>
                            <span class="cat-date">@cat.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>