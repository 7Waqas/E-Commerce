@model E_Commerce.Models.Category
@{
    ViewData["Title"] = "Edit Category";
}

<div class="form-page">
    <div class="container">
        <div class="form-box">
            <div class="form-box-header">
                <a href="/Category/Index" class="back-btn"><i class="fas fa-arrow-left"></i></a>
                <h2>Edit Category</h2>
            </div>
            <form asp-action="Edit" method="post" class="product-form">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="CreatedAt" type="hidden" />
                <div class="form-group-custom">
                    <label><i class="fas fa-folder"></i> Category Name</label>
                    <input asp-for="Name" class="input-field" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>
                <div class="form-group-custom">
                    <label><i class="fas fa-align-left"></i> Description <span class="optional">(optional)</span></label>
                    <textarea asp-for="Description" class="input-field textarea-field" rows="3"></textarea>
                </div>
                <div class="form-actions">
                    <a href="/Category/Index" class="btn-cancel">Cancel</a>
                    <button type="submit" class="btn-save">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>