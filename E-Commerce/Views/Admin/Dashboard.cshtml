@model List<E_Commerce.Models.Product>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="dashboard-page">
    <div class="container">

        <div class="dash-header">
            <div>
                <h1 class="dash-title">Admin Dashboard</h1>
                <p class="dash-sub">Manage your product listings</p>
            </div>
            <a href="/Product/Create" class="add-product-btn" aria-label="Add new product">
                <i class="fas fa-plus"></i> Add Product
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="success-toast">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
            </div>
        }

        <div class="stats-row">
            <div class="stat-card">
                <span class="stat-num">@Model.Count</span>
                <span class="stat-label">Total Products</span>
            </div>
            <div class="stat-card">
                <span class="stat-num">@Model.Count(p => p.CreatedAt.Date == DateTime.Today)</span>
                <span class="stat-label">Added Today</span>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">📦</div>
                <h3>No products yet</h3>
                <p>Click "Add Product" to get started</p>
            </div>
        }
        else
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>Description</th>
                            <th>URL</th>
                            <th>Added</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            <tr>
                                <td>@product.Id</td>
                                <td class="td-title">@product.Title</td>
                                <td class="td-desc">@product.Description</td>
                                <td><a href="@product.ProductUrl" target="_blank" class="url-link"><i class="fas fa-external-link-alt"></i> Visit</a></td>
                                <td>@product.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="td-actions">
                                    <a href="/Product/Edit/@product.Id" class="btn-edit">
                                        <i class="fas fa-pencil-alt"></i> Edit
                                    </a>
                                    <form asp-action="Delete" asp-controller="Product" method="post" style="display:inline"
                                          onsubmit="return confirm('Delete this product?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@product.Id" />
                                        <button type="submit" class="btn-delete">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>