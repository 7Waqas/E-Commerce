@model E_Commerce.Models.AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Login";
}

<div class="login-page">
    <div class="login-box">
        <div class="login-header">
            <div class="login-icon">🛡️</div>
            <h2>Admin Access</h2>
            <p>Enter your credentials to continue</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error">
                <i class="fas fa-exclamation-triangle"></i>
                @Html.ValidationSummary(true)
            </div>
        }

        <form asp-action="Login" method="post" class="login-form" aria-label="Admin login form">
            @Html.AntiForgeryToken()

            <div class="form-group-custom">
                <label for="Username"><i class="fas fa-user"></i> Username</label>
                <div class="input-wrap">
                    <i class="fas fa-user input-icon" aria-hidden="true"></i>
                    <input asp-for="Username" id="Username" class="input-field" placeholder="Enter username" autocomplete="username" />
                </div>
                <span asp-validation-for="Username" class="field-error"></span>
            </div>

            <div class="form-group-custom">
                <label for="Password"><i class="fas fa-lock"></i> Password</label>
                <div class="input-wrap">
                    <i class="fas fa-lock input-icon" aria-hidden="true"></i>
                    <input asp-for="Password" id="Password" class="input-field" type="password" placeholder="Enter password" autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <button type="submit" class="login-submit-btn">
                <i class="fas fa-sign-in-alt"></i> Login to Dashboard
            </button>
        </form>

        <a href="/" class="back-link">← Back to Store</a>
    </div>
</div>